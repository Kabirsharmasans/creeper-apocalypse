{
  "schemaVersion": 1,
  "id": "creeper-apocalypse-escalation",
  "version": "${version}",
  "name": "Creeper Apocalypse Escalation",
  "description": "Replace all mob spawns with Creepers! Features auto-escalating spawn rates, milestone events, special creeper variants, and streaming features.",
  "authors": [
    "CreeperApocalypse Team"
  ],
  "contact": {
    "homepage": "https://github.com/Kabirsharmasans/creeper-apocalypse",
    "sources": "https://github.com/Kabirsharmasans/creeper-apocalypse",
    "issues": "https://github.com/Kabirsharmasans/creeper-apocalypse/issues"
  },
  "license": "MIT",
  "icon": "assets/creeper-apocalypse/icon.png",
  "environment": "*",
  "entrypoints": {
    "main": [
      "com.creeperapocalypse.CreeperApocalypse"
    ],
    "client": [
      "com.creeperapocalypse.client.CreeperApocalypseClient"
    ]
  },
  "mixins": [
    "creeper-apocalypse.mixins.json"
  ],
  "accessWidener": "creeper-apocalypse.accesswidener",
  "depends": {
    "fabricloader": ">=${loader_version}",
    "minecraft": "~${minecraft_version}",
    "java": ">=21",
    "fabric-api": "*"
  },
  "suggests": {
    "another-mod": "*"
  },
  "custom": {
    "modmenu": {
      "links": {
        "modmenu.discord": "https://discord.gg/creeperapocalypse"
      }
    }
  }
}
